{
    "name": "andino/products-mvc",
    "description": "Pure PHP MVC migration of AndinoProducts backed by MongoDB Atlas",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "ext-mongodb": "*",
        "mongodb/mongodb": "2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\Andino\\Products\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
